  "ai_content": {
    "基督城": {
      "intro": "基督城是新西蘭南島最大城市，也是南島的文化與商業中心。這裡保存著英式風格的建築與現代化的城市景觀。此區相關景點：基督城植物園、坎特伯雷博物館、基督城藝術中心。",
      "spot_subtitles": {}
    },
    "Lake Tekpo": {
      "intro": "Lake Tekapo 是一個以明亮的藍色湖水而聞名的旅遊勝地。這裡的夜空更是被認定為全球最佳的觀星地點之一。此區相關景點：Mt. John Observatory、Tekapo Springs、Church of the Good Shepherd。",
      "spot_subtitles": {
        "Mt. John Observatory": "最佳的夜空觀星地點，有導覽團可報名。",
        "Tekapo Springs": "四季皆宜的溫泉與水上娛樂設施。"
      }
    },
    "Mt. Cook": {
      "intro": "Mt. Cook 是新西蘭最高的山峰，擁有壯麗的自然景觀。這裡是登山健行者的天堂，擁有多條絕佳步道可供探索。此區相關景點：Tasman Glacier Walk、Hooker Valley Track、Mt. Cook Visitor Centre。",
      "spot_subtitles": {
        "Tasman Glacier Walk": "走在冰河上，體驗壯觀的冰川景觀。",
        "Hooker Valley Track": "如詩如畫的健行步道，適合各種程度的遊客。"
      }
    },
    "皇后鎮": {
      "intro": "皇后鎮被譽為冒險之都，是每位探險者必訪的熱點。這裡提供各種刺激的活動，從滑雪到極限運動應有盡有。此區相關景點：滑車、滑雪、米爾福峽灣一日遊。",
      "spot_subtitles": {
        "滑車": "挑戰自我，體驗高空滑索的刺激。",
        "滑雪": "冬季滑雪勝地，適合各種技術的滑雪者。"
      }
    },
    "奧克蘭": {
      "intro": "奧克蘭是新西蘭最大的城市，也是主要的商業與文化樞紐。這裡擁有迷人的自然景觀與豐富的多元文化。此區相關景點：奧克蘭博物館、天空塔、維多利亞街。",
      "spot_subtitles": {}
    },
    "北島": {
      "intro": "北島是新西蘭的主要島嶼之一，以其壯麗的自然環境和熱情的地熱活動著稱。這裡擁有多樣的自然奇觀，是探索新西蘭文化的最佳地點。此區相關景點：陶波、羅托魯瓦、懷哈科島。",
      "spot_subtitles": {}
    },
    "羅托魯瓦": {
      "intro": "羅托魯瓦是以地熱溫泉聞名的城市，吸引著眾多旅客前來放鬆身心。這裡的毛利文化與活動也讓人印象深刻，充滿獨特魅力。此區相關景點：地熱公園、毛利文化村、羅托魯瓦湖。",
      "spot_subtitles": {}
    }
  }
}