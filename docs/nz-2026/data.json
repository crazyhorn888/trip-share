  "ai_content": {
    "基督城": {
      "intro": "基督城是新西蘭南島的主要城市，以其美麗的花園和英式建築聞名。這裡最大的亮點是重建後的城市中心和雅芳河沿岸的美麗步道。參觀時可以留意當地的公園及美食餐廳，享受悠閒的氛圍。"
    },
    "Lake Tekpo": {
      "intro": "Lake Tekpo 是以其驚豔的碧藍湖水和周圍的雪山景色而聞名的旅遊勝地。這裡的天文觀景設施非常優秀，是觀星愛好者的理想之地。來訪時不要忘記攜帶相機，捕捉這片美景的每個瞬間。"
    },
    "待定(彈性)": {
      "intro": "這個彈性的景點能根據您的興趣和時間安排進行變化，讓每一次旅程都充滿新鮮感。無論是自然探險還是文化體驗，您都能找到適合的活動。建議事先查明目的地的開放時間及交通資訊，以便更好地安排行程。"
    },
    "Mt. Cook": {
      "intro": "Mt. Cook 是新西蘭最高峰，擁有壯觀的高山景觀和多條健行步道。這裡是登山健行者的天堂，也是攝影愛好者的理想拍攝地點。訪問時記得查看天氣預報，提前規劃行程以確保安全。"
    },
    "皇后鎮": {
      "intro": "皇后鎮是新西蘭最受歡迎的旅遊城市，以其冒險活動和美麗湖泊景觀聞名。無論是滑雪、蹦極還是船遊，這裡都有無盡的刺激選擇。來訪時可以考慮多做計畫，因為活動選擇眾多，容易讓人感到眼花撩亂。"
    },
    "奧克蘭": {
      "intro": "奧克蘭是新西蘭最大的城市，擁有融合文化、美食和購物的多元體驗。這裡的天空塔是最具象徵性的地標，也是俯瞰全市的絕佳觀景點。建議提前預訂天空塔的門票，以避開長時間排隊。"
    },
    "北島": {
      "intro": "北島是新西蘭的文化和自然景觀多樣的地方，擁有壯麗的海灘和豐富的原住民文化。您可以在這裡體驗到如羅托魯瓦的溫泉、塔普爾的火山活動等自然奇觀。規劃行程時，務必留意各地的開放時間及交通方式。"
    },
    "羅托魯瓦": {
      "intro": "羅托魯瓦以其地熱活動和毛利文化聞名，是體驗新西蘭獨特文化的好地方。這裡擁有熱泉、泥漿噴發等自然景觀，值得一探究竟。參加毛利文化晚餐時，建議提前預約以確保有座位。"
    }
  }
}