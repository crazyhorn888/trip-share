  "ai_content": {
    "基督城": {
      "intro": "基督城是紐西蘭南島的最大城市，以其優美的公園和英國殖民風情聞名。這裡的植物園和重建後的市中心非常值得造訪。實用小提醒：不要錯過乘坐復古的有軌電車，感受城市的歷史魅力。"
    },
    "Lake Tekpo": {
      "intro": "Lake Tekpo 是一個美麗的高山湖泊，以其獨特的藍色湖水和周圍壯麗的山景聞名。這裡是觀星愛好者的夢想地點，擁有清晰的夜空。實用小提醒：秋冬季節來訪可享受更少的遊客和更壯觀的藍冰景象。"
    },
    "Mt. Cook": {
      "intro": "Mt. Cook 是紐西蘭最高的山峰，適合進行各種戶外活動，包括健行和登山。這裡的壯麗雪山景觀和周圍冰川壯觀無比。實用小提醒：記得查詢天氣預報，以便選擇最佳的登山路線。"
    },
    "皇后鎮": {
      "intro": "皇后鎮被譽為冒險之都，擁有各種極限運動和戶外活動，如蹦極跳和滑翔傘等。這裡的美景和多樣的活動使其成為每位遊客的首選地。實用小提醒：提前預訂熱門活動，以確保你的名額。"
    },
    "奧克蘭": {
      "intro": "奧克蘭是紐西蘭的最大城市，擁有多元文化和繁忙的都市生活。這裡的天空塔和美麗的海港都是不容錯過的景點。實用小提醒：利用公共交通系統，可以輕鬆便捷地探索城市各大景點。"
    },
    "北島": {
      "intro": "北島擁有豐富的自然美景和文化遺產，是紐西蘭兩個主要島嶼之一。這裡的羅托魯瓦和懷托摩萊洞都值得一遊。實用小提醒：駕車自遊行最能充分體驗北島的風土人情。"
    },
    "羅托魯瓦": {
      "intro": "羅托魯瓦以其豐富的地熱景觀和毛利文化而著稱，是旅遊愛好者不可錯過的目的地。這裡的間歇泉和溫泉提供獨特的放鬆體驗。實用小提醒：記得提前預約熱門的地熱區導覽，以確保最佳體驗。"
    }
  }
