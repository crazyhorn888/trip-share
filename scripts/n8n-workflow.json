    {
      "parameters": {
        "jsCode": "const tripData = $('組合 JSON 檔案').item.json;\nconst tripsResp = $input.item.json;\n\nlet trips = [];\nlet tripsSha = null;\n\nif (tripsResp.sha && tripsResp.content) {\n  tripsSha = tripsResp.sha;\n  try {\n    const parsed = JSON.parse(Buffer.from(tripsResp.content, 'base64').toString('utf-8'));\n    trips = parsed.trips || [];\n  } catch(e) {}\n}\n\nconst entry = {\n  trip_id:      tripData.trip_id,\n  trip_name:    tripData.trip_name,\n  emoji:        tripData.trip_emoji || '✈️',\n  status:       tripData.trip_status || '規劃中',\n  date_range:   tripData.date_range,\n  last_updated: tripData.last_updated\n};\n\nconst idx = trips.findIndex(t => t.trip_id === tripData.trip_id);\nif (idx >= 0) {\n  trips[idx] = entry;\n} else {\n  trips.push(entry);\n}\n\nconst b64 = Buffer.from(JSON.stringify({ trips }, null, 2)).toString('base64');\nconst putBody = {\n  message: `trips: sync ${tripData.trip_id}`,\n  content: b64,\n  ...(tripsSha ? { sha: tripsSha } : {})\n};\n\nreturn [{ json: { ...tripData, trips_put_body: putBody } }];"
      },
