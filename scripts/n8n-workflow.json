      "name": "收到同步請求",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "d4a7b3c2-1e5f-4a8b-9c3d-2f6e1a4b7c8d"
    },
    {
      "parameters": {
        "jsCode": "const payload = $input.item.json.body;\n\nconst costItems = payload.cost_split || [];\nconst summary = {\n  zeyu:     { name: '哲宇家', owed: 0, paid: 0, remaining: 0, pct: 0 },\n  shengmin: { name: '聖閔家', owed: 0, paid: 0, remaining: 0, pct: 0 }\n};\n\nfor (const item of costItems) {\n  summary.zeyu.owed     += parseFloat(item.zeyu_owed     || 0);\n  summary.zeyu.paid     += parseFloat(item.zeyu_paid     || 0);\n  summary.shengmin.owed += parseFloat(item.shengmin_owed || 0);\n  summary.shengmin.paid += parseFloat(item.shengmin_paid || 0);\n}\n\nfor (const f of Object.values(summary)) {\n  f.remaining = Math.round(f.owed - f.paid);\n  f.pct = f.owed > 0 ? Math.round(f.paid / f.owed * 1000) / 10 : 0;\n}\n\nconst locationHash = [...(payload.locations || [])].sort().join('|');\n\nconst now = new Date().toLocaleString('zh-TW', {\n  timeZone: 'Asia/Taipei',\n  year: 'numeric', month: '2-digit', day: '2-digit',\n  hour: '2-digit', minute: '2-digit'\n});\n\nreturn [{ json: { ...payload, cost_summary: summary, location_hash: locationHash, last_updated: now } }];"
      },
      "id": "n2-derive",
      "name": "計算衍生資料",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/crazyhorn888/trip-share/contents/docs/{{ $json.trip_id }}/cache.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "n3-get-cache",
      "name": "讀取 cache.json",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "QoK9TA32LNBMbtRX", "name": "GitHub Token" }
      }
    },
    {
      "parameters": {
        "jsCode": "const tripData = $('計算衍生資料').item.json;\nconst cacheResp = $input.item.json;\n\nlet cached = { location_hash: '', ai_content: {} };\nlet cacheSha = null;\n\nif (cacheResp.sha && cacheResp.content) {\n  cacheSha = cacheResp.sha;\n  try {\n    cached = JSON.parse(Buffer.from(cacheResp.content, 'base64').toString('utf-8'));\n  } catch(e) {}\n}\n\nconst newLocations = (tripData.locations || [])\n  .filter(loc => !(loc in (cached.ai_content || {})));\n\nreturn [{ json: {\n  ...tripData,\n  cached_ai:     cached.ai_content || {},\n  cache_sha:     cacheSha,\n  new_locations: newLocations,\n  needs_ai:      newLocations.length > 0\n} }];"
      },
      "id": "n4-check-hash",
      "name": "比對 hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "id": "c1",
            "leftValue": "={{ $json.needs_ai }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "equals" }
          }],
          "combinator": "and"
        }
      },
      "id": "n5-if-ai",
      "name": "需要 AI 更新？",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst prompt = '請用繁體中文為以下景點各寫一段簡短介紹。每個景點只需 3 句話以內，重點放在「這個地方是什麼、最值得去的理由、一個實用小提醒」。\\n\\n景點列表：' + d.new_locations.join('、') + '\\n\\n請以 JSON 格式回覆，格式範例：{ \"景點名\": { \"intro\": \"3句以內的介紹\" } }。只回傳 JSON，不要其他說明文字。';\n\nreturn [{ json: { ...d, openai_body: { model: 'gpt-4o-mini', max_tokens: 1024, messages: [{ role: 'user', content: prompt }] } } }];"
      },
      "id": "n6a-prep-openai",
      "name": "組合 OpenAI 請求",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1220, 160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.openai_body) }}",
        "options": {}
      },
      "id": "n6-claude",
      "name": "呼叫 OpenAI API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 160],
      "credentials": {
        "httpHeaderAuth": { "id": "rfj4i0z02gn3qDDD", "name": "OpenAI API Key" }
      }
    },
    {
      "parameters": {
        "jsCode": "const tripData = $('比對 hash').item.json;\nconst openaiResp = $input.item.json;\n\nlet newAI = {};\ntry {\n  const rawText = openaiResp.choices[0].message.content.trim();\n  const match = rawText.match(/\\{[\\s\\S]*\\}/);\n  if (match) newAI = JSON.parse(match[0]);\n} catch(e) {\n  console.log('AI parse error:', e.message);\n}\n\nreturn [{ json: {\n  ...tripData,\n  ai_content:   { ...tripData.cached_ai, ...newAI },\n  ai_updated:   true,\n  ai_new_count: Object.keys(newAI).length\n} }];"
      },
      "id": "n7-merge-ai",
      "name": "合併 AI 內容（OpenAI）",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 160]
    },
    {
      "parameters": {
        "jsCode": "const tripData = $input.item.json;\nreturn [{ json: { ...tripData, ai_content: tripData.cached_ai, ai_updated: false, ai_new_count: 0 } }];"
      },
      "id": "n8-use-cache",
      "name": "使用快取 AI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 440]
