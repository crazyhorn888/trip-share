      "parameters": {
        "jsCode": "const d = $('組合 JSON 檔案').item.json;\nconst shaResp = $input.item.json;\n\nconst putBody = {\n  message: `sync(${d.trip_id}): ${d.last_updated}${d.ai_updated ? ' [AI updated ' + d.ai_new_count + ' spots]' : ''}`,\n  content: d.data_json_b64,\n  ...(shaResp.sha ? { sha: shaResp.sha } : {})\n};\n\nreturn [{ json: { ...d, data_put_body: putBody } }];"
      },
